<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OCC - OpenCode Controller</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="container nav-inner">
      <div class="logo">OCC</div>
      <ul class="nav-links">
        <li><a href="/?lang=<%= lang %>" class="active"><%= t.nav.home %></a></li>
        <li><a href="/install?lang=<%= lang %>"><%= t.nav.install %></a></li>
        <li><a href="/api?lang=<%= lang %>"><%= t.nav.api %></a></li>
        <li><a href="/demo?lang=<%= lang %>"><%= t.nav.demo %></a></li>
      </ul>
      <div class="nav-controls">
        <button id="theme-toggle" class="theme-toggle">🌙</button>
        <select id="lang-toggle" class="lang-toggle">
          <option value="en" <%= lang === 'en' ? 'selected' : '' %>>EN</option>
          <option value="zh" <%= lang === 'zh' ? 'selected' : '' %>>中文</option>
        </select>
      </div>
    </div>
  </nav>

  <div class="hero">
    <div class="hero-content">
      <h1><%= t.hero.title %></h1>
      <p><%= t.hero.subtitle %></p>
      <a href="/install?lang=<%= lang %>" class="cta-button"><%= t.hero.cta %></a>
    </div>
  </div>

  <section>
    <div class="container">
      <h2 class="section-title"><%= t.features.title %></h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3><%= t.features.session.title %></h3>
          <p><%= t.features.session.desc %></p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🚀</div>
          <h3><%= t.features.autoStart.title %></h3>
          <p><%= t.features.autoStart.desc %></p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔄</div>
          <h3><%= t.features.automation.title %></h3>
          <p><%= t.features.automation.desc %></p>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p><%= t.footer.text %></p>
    </div>
  </footer>
  <script src="/js/main.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Demo - OCC</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="container nav-inner">
      <div class="logo">OCC</div>
      <ul class="nav-links">
        <li><a href="/?lang=<%= lang %>"><%= t.nav.home %></a></li>
        <li><a href="/install?lang=<%= lang %>"><%= t.nav.install %></a></li>
        <li><a href="/api?lang=<%= lang %>"><%= t.nav.api %></a></li>
        <li><a href="/demo?lang=<%= lang %>" class="active"><%= t.nav.demo %></a></li>
      </ul>
      <div class="nav-controls">
        <button id="theme-toggle" class="theme-toggle">🌙</button>
        <select id="lang-toggle" class="lang-toggle">
          <option value="en" <%= lang === 'en' ? 'selected' : '' %>>EN</option>
          <option value="zh" <%= lang === 'zh' ? 'selected' : '' %>>中文</option>
        </select>
      </div>
    </div>
  </nav>

  <section style="padding-top: 120px;">
    <div class="container">
      <h2 class="section-title"><%= t.demo.title %></h2>
      <p style="text-align: center; color: var(--text-secondary); margin-bottom: 3rem;"><%= t.demo.desc %></p>
      
      <div class="demo-terminal">
        <div class="terminal-header">
          <div class="terminal-dot"></div>
          <div class="terminal-dot"></div>
          <div class="terminal-dot"></div>
        </div>
        <div class="terminal-body">
          <div class="terminal-line">
            <span class="terminal-prompt">$</span>
            <span class="terminal-command">node skills/occ/scripts/bin/opencode-server.js create "Create a React login page"</span>
          </div>
          <div class="terminal-line" style="color: var(--text-secondary);">
            Session created: sess_abc123
          </div>
          <div class="terminal-line" style="color: var(--success);">
            ✓ OpenCode started and ready
          </div>
        </div>
      </div>

      <div class="demo-images" style="margin-top: 3rem;">
        <img src="https://raw.githubusercontent.com/gongxh13/opencode-controller/main/docs/images/openclaw-send.png" alt="OpenCLAW sends task" style="max-width: 100%; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
        <img src="https://raw.githubusercontent.com/gongxh13/opencode-controller/main/docs/images/opencode-receive.png" alt="OpenCode receives task" style="max-width: 100%; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); margin-top: 2rem;">
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p><%= t.footer.text %></p>
    </div>
  </footer>
  <script src="/js/main.js"></script>
</body>
</html>

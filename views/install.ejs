<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Installation - OCC</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="container nav-inner">
      <div class="logo">OCC</div>
      <ul class="nav-links">
        <li><a href="/?lang=<%= lang %>"><%= t.nav.home %></a></li>
        <li><a href="/install?lang=<%= lang %>" class="active"><%= t.nav.install %></a></li>
        <li><a href="/api?lang=<%= lang %>"><%= t.nav.api %></a></li>
        <li><a href="/demo?lang=<%= lang %>"><%= t.nav.demo %></a></li>
      </ul>
      <div class="nav-controls">
        <button id="theme-toggle" class="theme-toggle">🌙</button>
        <select id="lang-toggle" class="lang-toggle">
          <option value="en" <%= lang === 'en' ? 'selected' : '' %>>EN</option>
          <option value="zh" <%= lang === 'zh' ? 'selected' : '' %>>中文</option>
        </select>
      </div>
    </div>
  </nav>

  <section style="padding-top: 120px;">
    <div class="container">
      <h2 class="section-title"><%= t.install.title %></h2>
      <p style="text-align: center; color: var(--text-secondary); margin-bottom: 3rem;"><%= t.install.desc %></p>
      
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">1</div>
          <h3><%= t.install.step1 %></h3>
        </div>
        <div class="feature-card">
          <div class="feature-icon">2</div>
          <h3><%= t.install.step2 %></h3>
        </div>
        <div class="feature-card">
          <div class="feature-icon">3</div>
          <h3><%= t.install.step3 %></h3>
        </div>
      </div>

      <div style="margin-top: 3rem;">
        <h3 style="margin-bottom: 1rem;">Usage</h3>
        <div class="code-block">
          <code><%= t.install.code %></code>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p><%= t.footer.text %></p>
    </div>
  </footer>
  <script src="/js/main.js"></script>
</body>
</html>
